// AgentHub - Multi-Agent Team Collaboration Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ WORKSPACE ============
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  context     String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      Member[]
  agents       Agent[]
  issues       Issue[]
  projects     Project[]
  skills       Skill[]
  chatSessions ChatSession[]
}

// ============ USER & MEMBER ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Member[]
}

model Member {
  id          String   @id @default(cuid())
  role        String   @default("member")
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

// ============ AGENT ============
model Agent {
  id           String   @id @default(cuid())
  name         String
  description  String?
  avatar       String?
  provider     String   @default("claude")
  instructions String?
  status       String   @default("idle")
  maxConcurrent Int     @default(3)
  visibility   String   @default("workspace")
  customEnv    String?
  customArgs   String?
  mcpConfig    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  skills AgentSkill[]
  tasks  AgentTask[]
}

// ============ SKILL ============
model Skill {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String
  category    String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  agents AgentSkill[]
}

model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
}

// ============ ISSUE ============
model Issue {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("backlog")
  priority    String    @default("none")
  order       Int       @default(0)
  assigneeType String?
  assigneeId   String?
  creatorType  String    @default("member")
  creatorId    String?
  projectId    String?
  dueDate      DateTime?
  labels       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])

  comments Comment[]
  tasks    AgentTask[]
  activity ActivityLog[]
}

// ============ COMMENT ============
model Comment {
  id        String   @id @default(cuid())
  content   String
  authorType String   @default("member")
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

// ============ AGENT TASK ============
model AgentTask {
  id          String    @id @default(cuid())
  status      String    @default("queued")
  output      String?
  tokensUsed  Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  issueId String?
  issue   Issue? @relation(fields: [issueId], references: [id])

  chatSessionId String?
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id])
}

// ============ PROJECT ============
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  status      String   @default("planned")
  priority    String   @default("none")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  issues Issue[]
}

// ============ CHAT SESSION ============
model ChatSession {
  id          String   @id @default(cuid())
  title       String?
  agentId     String?
  unreadCount Int      @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  messages ChatMessage[]
  tasks    AgentTask[]
}

// ============ CHAT MESSAGE ============
model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ============ ACTIVITY LOG ============
model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorType  String?
  actorId    String?
  metadata   String?
  createdAt  DateTime @default(now())

  issueId String?
  issue   Issue? @relation(fields: [issueId], references: [id])
}
